<?xml version="1.0" encoding="utf-8"?>
<resources>

    <style name="Theme.AudioAnalyser" parent="android:Theme.Material.Light.NoActionBar" />

    <style name="Theme.AudioAnalyser.Splash" parent="Theme.SplashScreen">
        <!-- Set the splash screen background -->
        <item name="windowSplashScreenBackground">@color/black</item>
        <!-- Use windowSplashScreenAnimatedIcon to add a drawable -->
        <item name="windowSplashScreenAnimatedIcon">@drawable/splash_image</item>
        <!-- Set the theme of the Activity that follows your splash screen -->
        <item name="postSplashScreenTheme">@style/Theme.AudioAnalyser</item>
    </style>
</resources>